nav#nav
  div#nav-group
    span#blog-info
      a.nav-site-title(href=url_for('/'))
        if theme.nav.logo
          img.site-icon(src=url_for(theme.nav.logo) alt='Logo')
        if theme.nav.display_title
          span.site-name=config.title
        if is_post()
          a.nav-page-title(href=url_for('/'))
            span.site-name=(page.title || config.title)
    #menus
      if theme.menu
        != partial('includes/header/menu_item', {}, {cache: true})
    #nav-right
      //- #travellings
      //-   a.site-page(href=url_for('https://travellings.cn/go.html') title="随机前往一个开往项目网站")
      //-     i.iconfont.icat-subway
      //- #random
      //-   a.site-page(href=url_for('javascript:toRandomPost()') title="随机前往一个文章")
      //-     i.iconfont.icat-random

      if theme.search.use
        #search-button
          span.site-page.social-icon.search
            i.fas.fa-search.fa-fw
            span= ' ' + _p('search.title')
        #toggle-menu
            a.site-page(href="javascript:void(0);" title="aside-menu")
              i.fas.fa-bars.fa-fw